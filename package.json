{
  "name": "resound-sound",
  "version": "0.1.0",
  "description": "Web Audio API instrument library extracted from the Resound game.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/editor",
    "!src/**/*.test.js"
  ],
  "scripts": {
    "test": "jest",
    "start": "concurrently --names webpack,tsc,editor \"npm run webpack\" \"npm run watch:types\" \"cd src/editor && npm start\"",
    "webpack": "webpack --watch --mode development",
    "watch:types": "tsc --watch --preserveWatchOutput",
    "build": "webpack --mode production && tsc",
    "build:types": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calebjedhugo/resound-sound.git"
  },
  "keywords": [
    "web-audio",
    "audio",
    "sound",
    "instruments",
    "synthesis"
  ],
  "author": "Caleb Hugo",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/calebjedhugo/resound-sound/issues"
  },
  "homepage": "https://github.com/calebjedhugo/resound-sound#readme",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
